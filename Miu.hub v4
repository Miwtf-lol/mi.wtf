-- ============================================
-- Target detection
-- ============================================
local target
local enemyFolder = workspace:WaitForChild("Enemies", 9e9) -- or whatever folder name

local function updateTarget()
    for _, child in ipairs(enemyFolder:GetChildren()) do
        if child:GetAttribute("Targetable") then
            target = child
            return
        end
    end
    target = nil
end

enemyFolder.ChildAdded:Connect(updateTarget)
enemyFolder.ChildRemoved:Connect(updateTarget)
updateTarget()

-- ============================================
-- Heartbeat loop
-- ============================================
RunService.Heartbeat:Connect(function(deltaTime)
    -- Silent Aim click logic
    if isSilentAimEnabled then
        local clickInterval = 1 / cps
        local accumulator = 0
        accumulator = accumulator + (cps * deltaTime)
        
        while accumulator >= 1 do
            task.spawn(autoClick)
            accumulator = accumulator - 1
        end
    end
    
    -- Auto-target logic (if enabled and target exists)
    if target and LocalPlayer.Character then
        local character = LocalPlayer.Character
        local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
        local humanoid = character:FindFirstChildOfClass("Humanoid")
        
        if humanoidRootPart and humanoid and humanoid.Health > 0 then
            if humanoidRootPart:FindFirstChild("BodyVelocity") or target:GetAttribute("Owner") == LocalPlayer.Name then
                -- skip if owned or has velocity
            else
                local targetVelocity = target.AssemblyLinearVelocity
                local targetSpeed = targetVelocity.Magnitude
                local direction = (humanoidRootPart.Position - target.Position).Unit
                
                if targetSpeed > 0.5 and targetVelocity.Unit:Dot(direction) > 0.7 then
                    local distance = (humanoidRootPart.Position - target.Position).Magnitude
                    local pingSec = NetworkStats:GetValue() / 1000
                    local timeToReach = distance / targetSpeed
                    local prediction = timeToReach + 0.45
                    
                    if targetSpeed > 150 then
                        prediction = prediction + (targetSpeed / 5000)
                    end
                    
                    if timeToReach <= prediction and (tick() - lastFireTime) > 0.5 then
                        task.spawn(pressF)
                        lastFireTime = tick()
                    end
                end
            end
        end
    end
end)

