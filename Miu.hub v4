-- Decryption helper (removed xor layer since original used v7() for strings)
-- Original v7() just XORs strings with a key for obfuscation
local function decrypt(str, key)
    local result = {}
    for i = 1, #str, 2 do
        local byte1 = string.byte(str, i)
        local byte2 = string.byte(str, i + 1)
        local keyByte = string.byte(key, (i % #key) + 1)
        local decrypted = bit32.bxor(byte1, byte2, keyByte) % 256
        table.insert(result, string.char(decrypted))
    end
    return table.concat(result)
end

