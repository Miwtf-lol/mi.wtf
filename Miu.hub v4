local function CreateTab(name, icon)
    local tab = Instance.new("Frame")
    tab.Name = name
    tab.Size = UDim2.new(1, 0, 1, -40)
    tab.Position = UDim2.new(0, 0, 0, 40)
    tab.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    tab.BorderSizePixel = 0
    tab.Visible = false
    tab.Parent = MainFrame
    
    -- Tab button
    local tabButton = Instance.new("TextButton")
    tabButton.Size = UDim2.new(0, 80, 0, 35)
    tabButton.Position = UDim2.new(0, (#Tabs * 85), 0, 2)
    tabButton.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
    tabButton.BorderSizePixel = 0
    tabButton.TextColor3 = Color3.fromRGB(200, 200, 200)
    tabButton.Text = name
    tabButton.Font = Enum.Font.Gotham
    tabButton.TextScaled = true
    tabButton.Parent = GUI:FindFirstChild("TabBar") or MainFrame
    
    local UICorner = Instance.new("UICorner")
    UICorner.CornerRadius = UDim.new(0, 6)
    UICorner.Parent = tabButton
    
    tabButton.MouseButton1Click:Connect(function()
        for _, t in pairs(Tabs) do
            t.Frame.Visible = false
            t.Button.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
        end
        tab.Visible = true
        tabButton.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
        CurrentTab = name
    end)
    
    Tabs[name] = { Frame = tab, Button = tabButton }
    return tab
end

