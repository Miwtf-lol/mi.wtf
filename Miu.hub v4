-- ============================================
-- Tạo các tab và chức năng
-- ============================================
local function SetupTabs()
    -- Tab Combat
    local combatTab = CreateTab("Combat")
    CreateSection(combatTab, "Auto Farm")
    
    CreateToggle(combatTab, "Auto Farm", false, function(state)
        autoFarmEnabled = state
        CreateNotification("Auto Farm", state and "Enabled" or "Disabled", 2)
    end)
    
    CreateToggle(combatTab, "Silent Aim", false, function(state)
        aimEnabled = state
        CreateNotification("Silent Aim", state and "Enabled" or "Disabled", 2)
    end)
    
    CreateSlider(combatTab, "Auto Click Delay", 0.01, 1, 0.1, function(value)
        autoClickDelay = value
    end)
    
    CreateSlider(combatTab, "Target Distance", 10, 200, 50, function(value)
        targetDistance = value
    end)
    
    -- Tab Movement
    local moveTab = CreateTab("Movement")
    CreateSection(moveTab, "Player Settings")
    
    CreateToggle(moveTab, "Speed Enabled", false, function(state)
        speedEnabled = state
        if state and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
            LocalPlayer.Character.Humanoid.WalkSpeed = walkSpeed
        elseif LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
            LocalPlayer.Character.Humanoid.WalkSpeed = 16
        end
        CreateNotification("Speed", state and "Enabled" or "Disabled", 2)
    end)
    
    CreateSlider(moveTab, "WalkSpeed", 16, 250, 16, function(value)
        walkSpeed = value
        if speedEnabled and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
            LocalPlayer.Character.Humanoid.WalkSpeed = value
        end
    end)
    
    CreateToggle(moveTab, "Jump Enabled", false, function(state)
        jumpEnabled = state
        if state and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
            LocalPlayer.Character.Humanoid.JumpPower = jumpPower
        elseif LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
            LocalPlayer.Character.Humanoid.JumpPower = 50
        end
        CreateNotification("Jump", state and "Enabled" or "Disabled", 2)
    end)
    
    CreateSlider(moveTab, "JumpPower", 50, 500, 50, function(value)
        jumpPower = value
        if jumpEnabled and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
            LocalPlayer.Character.Humanoid.JumpPower = value
        end
    end)
    
    -- Tab Visual
    local visTab = CreateTab("Visuals")
    CreateSection(visTab, "Graphics")
    
    CreateButton(visTab, "Remove Shadows & Fog", function()
        local lighting = game.Lighting
        lighting.GlobalShadows = false
        lighting.FogEnd = 9e9
        settings().Rendering.QualityLevel = 1
        
        for _, obj in pairs(game:GetDescendants()) do
            if obj:IsA("Part") or obj:IsA("MeshPart") or obj:IsA("UnionOperation") then
                obj.Material = Enum.Material.SmoothPlastic
                obj.Reflectance = 0
            elseif obj:IsA("Decal") or obj:IsA("Texture") then
                obj.Transparency = 1
            elseif obj:IsA("ParticleEmitter") or obj:IsA("Smoke") then
                obj.Enabled = false
            end
        end
        CreateNotification("Visuals", "Shadows, fog & effects removed", 2)
    end)
    
    CreateButton(visTab, "Remove Lighting Effects", function()
        for _, obj in pairs(game.Lighting:GetChildren()) do
            if obj:IsA("Sky") or obj:IsA("Atmosphere") or obj:IsA("BloomEffect") or obj:IsA("SunRaysEffect") then
                obj.Enabled = false
            end
        end
        CreateNotification("Lighting", "Effects disabled", 2)
    end)
    
    CreateButton(visTab, "Delete Trash/Props", function()
        for _, obj in pairs(game.Workspace:GetDescendants()) do
            if obj:IsA("ProximityPrompt") or obj:IsA("ClickDetector") then
                obj:Destroy()
            end
        end
        CreateNotification("Cleanup", "Trash removed", 2)
    end)
    
    -- Tab Misc
    local miscTab = CreateTab("Misc")
    CreateSection(miscTab, "Tools")
    
    CreateButton(miscTab, "Reset Character", function()
        if LocalPlayer.Character then
            LocalPlayer.Character:BreakJoints()
        end
    end)
    
    CreateButton(miscTab, "Rejoin Game", function()
        game:GetService("TeleportService"):Teleport(game.PlaceId, LocalPlayer)
    end)
    
    CreateButton(miscTab, "Server Hop", function()
        local HttpService = game:GetService("HttpService")
        local function getServers()
            local list = {}
            local cursor = ""
            local url = "https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?limit=100"
            if cursor ~= "" then
                url = url .. "&cursor=" .. cursor
            end
            
            local success, response = pcall(function()
                return game:HttpGetAsync(url)
            end)
            
            if success then
                local data = HttpService:JSONDecode(response)
                for _, server in pairs(data.data) do
                    if server.playing < server.maxPlayers then
                        table.insert(list, server.id)
                    end
                end
                cursor = data.nextPageCursor
            end
            
            return list
        end
        
        local servers = getServers()
        if #servers > 0 then
            local randomServer = servers[math.random(1, #servers)]
            game:GetService("TeleportService"):TeleportToPlaceInstance(game.PlaceId, randomServer, LocalPlayer)
        else
            CreateNotification("Server Hop", "No servers found", 2)
        end
    end)
    
    -- Hiển thị tab đầu tiên
    if Tabs["Combat"] then
        Tabs["Combat"].Frame.Visible = true
        Tabs["Combat"].Button.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    end
end

-- ============================================
-- Hệ thống Auto Farm
-- ============================================
local function AutoFarm()
    while isRunning do
        task.wait(autoClickDelay)
        
        if autoFarmEnabled then
            -- Tìm enemy gần nhất
            local closestEnemy = nil
            local closestDistance = targetDistance
            
            for _, player in pairs(Players:GetPlayers()) do
                if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                    local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
                    if humanoid and humanoid.Health > 0 then
                        local distance = (player.Character.HumanoidRootPart.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude
                        if distance < closestDistance then
                            closestEnemy = player
                            closestDistance = distance
                        end
                    end
                end
            end
            
            -- Tìm NPC/monster
            if not closestEnemy then
                for _, obj in pairs(workspace:GetDescendants()) do
                    if obj:IsA("Model") and obj:FindFirstChild("HumanoidRootPart") then
                        local humanoid = obj:FindFirstChildOfClass("Humanoid")
                        if humanoid and humanoid.Health > 0 and not Players:GetPlayerFromCharacter(obj) then
                            local distance = (obj.HumanoidRootPart.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude
                            if distance < closestDistance then
                                closestEnemy = obj
                                closestDistance = distance
                            end
                        end
                    end
                end
            end
            
            if closestEnemy and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                -- Move to target
                local hrp = LocalPlayer.Character.HumanoidRootPart
                local targetPos = closestEnemy:IsA("Player") and closestEnemy.Character.HumanoidRootPart.Position or closestEnemy.HumanoidRootPart.Position
                
                -- Auto click
                if closestDistance < 15 then
                    VirtualInput:SendMouseButtonEvent(0, 0, 0, true, game, 0)
                    task.wait(0.01)
                    VirtualInput:SendMouseButtonEvent(0, 0, 0, false, game, 0)
                end
            end
        end
        
        if speedEnabled and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
            LocalPlayer.Character.Humanoid.WalkSpeed = walkSpeed
        end
        
        if jumpEnabled and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
            LocalPlayer.Character.Humanoid.JumpPower = jumpPower
        end
    end
end

-- ============================================
-- Khởi chạy
-- ============================================
local function Main()
    InitializeGUI()
    SetupTabs()
    
    isRunning = true
    
    -- Start auto farm loop
    coroutine.wrap(AutoFarm)()
    
    CreateNotification("Script Hub", "Loaded successfully!", 3)
end

-- Chạy script
local success, err = pcall(Main)
if not success then
    warn("Script Hub Error: " .. tostring(err))
    -- Fallback notification using Instance
    local notify = Instance.new("Message")
    notify.Text = "Script Hub loaded! Press F7 to open GUI"
    notify.Parent = game:GetService("MessageBus")
    
    -- Create toggle keybind
    UserInputService.InputBegan:Connect(function(input, gpe)
        if not gpe and input.KeyCode == Enum.KeyCode.F7 then
            if GUI then
                GUI.Enabled = not GUI.Enabled
            end
        end
    end)
end
