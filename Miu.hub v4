-- Silent Aim Storage
-- ============================================
local silentAimTargets = {} -- stores {target, args} pairs
local lastClickTime = 0
local isSilentAimEnabled = false
local cps = 10 -- clicks per second
local silentAimKey = Enum.KeyCode.E
local lastFireTime = 0

-- Hook RemoteEvent firing to capture silent aim data
local oldNamecall
oldNamecall = hookmetamethod(game, "__namecall", newcclosure(function(self, ...)
    local method = getnamecallmethod()
    
    if method == "FireServer" and self:IsA("RemoteEvent") then
        return function(...)
            local args = {...}
            if #args == 1 and type(args[0]) == "table" then
                silentAimTargets[self] = args
            end
            return oldNamecall(self, ...)
        end
    end
    return oldNamecall(self, ...)
end))

-- ============================================
-- Auto-click function
-- ============================================
local function autoClick()
    VirtualInput:SendMouseButtonEvent(0, 0, 0, true, game, 0)
    VirtualInput:SendMouseButtonEvent(0, 0, 0, false, game, 0)
    
    local now = tick()
    if now - lastClickTime >= 0.025 then
        for remote, args in next, silentAimTargets do
            task.spawn(function()
                remote:FireServer(unpack(args[0]))
            end)
        end
        lastClickTime = now
    end
end

-- ============================================
-- Key press function (F key simulation)
