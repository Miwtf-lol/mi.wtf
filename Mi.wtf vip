-- ====== SMART AUTO PARRY ======
local function canParry(ball)
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then 
        return false 
    end

    local root = char.HumanoidRootPart
    local ballPos = ball.Position
    local velocity = ball.Velocity

    if velocity.Magnitude < 1 then return false end

    local distance = (ballPos - root.Position).Magnitude

    local direction = (root.Position - ballPos).Unit
    local dot = direction:Dot(velocity.Unit)
    if dot < 0.8 then return false end

    local timeToHit = distance / velocity.Magnitude

    local ping = mi_wtf.prediction.ping / 1000
    local adjustedTime = timeToHit - ping

    local finalTiming = mi_wtf.timing
    if mi_wtf.mobile then
        finalTiming = finalTiming + 0.05
    end

    return adjustedTime < finalTiming
end

