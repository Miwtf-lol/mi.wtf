-- Auto Parry Logic (Exact Allusive Prediction)
local function getBall()
    for _, obj in pairs(Workspace:GetChildren()) do
        if obj.Name == "ball" and obj:FindFirstChild("UnionOperation") then
            return obj
        end
    end
    return nil
end

local function predictPosition(ball, target)
    local ballPos = ball.Position
    local targetPos = target.Character.HumanoidRootPart.Position
    local direction = (targetPos - ballPos).Unit
    local distance = (targetPos - ballPos).Magnitude
    
    local timeToTarget = distance / mi_wtf.prediction.speed
    local gravityDrop = 0.5 * mi_wtf.prediction.gravity * timeToTarget^2
    
    return ballPos + (direction * distance) + Vector3.new(0, gravityDrop, 0)
end

local function canParry(ball)
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return false end

    local root = char.HumanoidRootPart
    local dir = (root.Position - ball.Position).Unit
    local vel = ball.Velocity.Unit

    local dot = dir:Dot(vel)
    if dot < 0.85 then return false end

    local distance = (ball.Position - root.Position).Magnitude
    local speed = ball.Velocity.Magnitude

    if speed < 1 then return false end

    local time = distance / speed

    return time < 0.3
end

