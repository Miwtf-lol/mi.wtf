-- HEARTBEAT
RunService.Heartbeat:Connect(function(dt)
    fpsCount += 1
    fpsTimer += dt
    frameTime += dt

    if fpsTimer >= 1 then
        local fps = math.floor(fpsCount / fpsTimer)
        fpsCount = 0; fpsTimer = 0
        FpsLabel.Text = "FPS: "..fps
        FpsLabel.TextColor3 = fps >= 50 and Color3.fromRGB(50,220,80) or fps >= 30 and Color3.fromRGB(255,200,0) or Color3.fromRGB(255,60,60)
        pcall(function()
            local ping = math.floor(Stats.Network.ServerStatsItem["Data Ping"]:GetValue())
            PingLabel.Text = "Ping: "..ping.."ms"
            PingLabel.TextColor3 = ping <= 80 and Color3.fromRGB(50,220,80) or ping <= 150 and Color3.fromRGB(255,200,0) or Color3.fromRGB(255,60,60)
        end)
    end

    if frameTime >= 0.1 then
        if spamActive then
            realCPS = math.floor(frameFireCount / frameTime)
            local mode = useKPS and "KPS" or "CPS"
            CpsCounterLabel.Text = realCPS.." "..mode
            if realCPS <= 100 then
                CpsCounterLabel.TextColor3 = Color3.fromRGB(255,60,60)
                CpsStroke.Color = Color3.fromRGB(255,60,60)
            elseif realCPS <= 150 then
                CpsCounterLabel.TextColor3 = Color3.fromRGB(255,200,0)
                CpsStroke.Color = Color3.fromRGB(255,200,0)
            else
                CpsCounterLabel.TextColor3 = Color3.fromRGB(50,220,80)
                CpsStroke.Color = Color3.fromRGB(50,220,80)
            end
        else
            CpsCounterLabel.Text = "0 "..(useKPS and "KPS" or "CPS")
            CpsCounterLabel.TextColor3 = LGRAY
            CpsStroke.Color = P1
        end
        frameFireCount = 0
        frameTime = 0
    end

    local ballContainer = workspace:FindFirstChild("Balls")
    local ball = ballContainer and ballContainer:GetChildren()[1]
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    local cam = workspace.CurrentCamera

    -- BALL TRAIL
    if ballTrail then
        if ball and ball:IsA("BasePart") then
            if ball ~= lastTrackedBall then
                lastTrackedBall = ball
                enableTrail(ball)
            end
        else
            if lastTrackedBall then
                lastTrackedBall = nil
                disableTrail()
            end
        end
    end

    -- AUTO PARRY — dùng biến parryCooldownTime từ slider
    if autoParry and remote and f_raw and ball and ball:IsA("BasePart") and hrp then
        local vel = ball.Velocity.Magnitude
        local toPlayer = hrp.Position - ball.Position
        local dist = toPlayer.Magnitude
        local isComing = vel > 1 and ball.Velocity.Unit:Dot(toPlayer.Unit) > 0

        local target = ball:GetAttribute("Target") or ball:GetAttribute("target")
            or ball:GetAttribute("TargetPlayer") or ball:GetAttribute("targetPlayer")
        local isMyBall = (target == LocalPlayer.Name)
            or (target == LocalPlayer.UserId)
            or (target == tostring(LocalPlayer.UserId))

        local hitDist = 20 + (vel * 0.18)
        local farDist = hitDist * 2.5
        local now = os.clock()

        if dist > farDist or not isComing then
            ballIsFar = true
        end

        if parryLocked then
            local timeSinceLastParry = now - lastParryTime
            if (ballIsFar and timeSinceLastParry >= parryCooldownTime) or timeSinceLastParry >= 0.6 then
                parryLocked = false
                hitDebounce = false
                ballIsFar = false
            end
        end

        if isMyBall and isComing and dist <= hitDist and not parryLocked and not hitDebounce then
            parryLocked = true
            hitDebounce = true
            lastParryTime = now
            ballIsFar = false

            c[3] = cam and cam.CFrame.LookVector or c[3]
            pcall(function() f_raw(remote, unpack(c)) end)

            task.spawn(PlayParry_Animation)

            task.delay(0.2, function()
                hitDebounce = false
            end)
        end
    end

    -- SPAM
    if spamActive and remote and f_raw then
        local rampSpeed = dt * 200
        if currentCPS < targetCPS then
            currentCPS = math.min(currentCPS + rampSpeed, targetCPS)
        end

        timeAccumulator += dt
        local interval = 1 / math.max(currentCPS, 1)
        while timeAccumulator >= interval do
            timeAccumulator -= interval
            pcall(function()
                c[3] = cam and cam.CFrame.LookVector or c[3]
                f_raw(remote, unpack(c))
                frameFireCount += 1
            end)
            if animFix then task.spawn(SpamParry_Animation) end
        end
    else
        timeAccumulator = 0
        currentCPS = 0
    end
end)
