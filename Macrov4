local draggingSlider = false
local lastSliderVal = (50-1)/(870-1)
local pendingSliderVal = lastSliderVal

local function applySlider(val)
    val = math.clamp(val, 0, 1)
    targetCPS = math.floor(1 + (getMax()-1)*val)
    SliderFill.Size = UDim2.new(val,0,1,0)
    SliderKnob.Position = UDim2.new(val,-6,0.5,-6)
    RateLabel.Text = (useKPS and "KPS: " or "CPS: ")..targetCPS
    lastSliderVal = val
end

local function updateSlider(val)
    val = math.clamp(val, 0, 1)
    local newCPS = math.floor(1 + (getMax()-1)*val)
    if not useKPS and newCPS > 800 and not warningShown then
        warningShown = true
        pendingSliderVal = val
        showWarning(
            function() applySlider(pendingSliderVal) end,
            function() applySlider(lastSliderVal) end
        )
        return
    end
    applySlider(val)
end

applySlider(lastSliderVal)

