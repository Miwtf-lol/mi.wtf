-- === AUTO PARRY ===
local function findNearestBall()
    local char = Player.Character
    if not char then return nil, math.huge end
    local humanoidRootPart = char:FindFirstChild("HumanoidRootPart")
    if not humanoidRootPart then return nil, math.huge end
    local rootPos = humanoidRootPart.Position
    
    local nearestBall = nil
    local nearestDist = math.huge
    
    local ballNames = {"Ball", "Football", "SoccerBall", "Basketball", "Volleyball", "Balloon", "Fireball", "Projectile", "Bullet", "Hitbox"}
    
    for _, obj in pairs(Workspace:GetDescendants()) do
        if obj:IsA("Part") or obj:IsA("MeshPart") or obj:IsA("BasePart") then
            local objName = obj.Name
            local isBall = false
            for _, bName in ipairs(ballNames) do
                if objName:find(bName) then
                    isBall = true
                    break
                end
            end
            if not isBall then
                if obj:IsA("BasePart") and obj.AssemblyLinearVelocity and obj.AssemblyLinearVelocity.Magnitude > 15 then
                    isBall = true
                end
            end
            if isBall then
                local dist = (obj.Position - rootPos).Magnitude
                if dist < nearestDist then
                    nearestDist = dist
                    nearestBall = obj
                end
            end
        end
    end
    
    return nearestBall, nearestDist
end

local function doParry()
    local parryKeys = {
        Enum.KeyCode.F,
        Enum.KeyCode.Q,
        Enum.KeyCode.E,
        Enum.KeyCode.R,
        Enum.KeyCode.ButtonR2,
    }
    
    for _, key in ipairs(parryKeys) do
        VirtualInputManager:SendKeyEvent(true, key, false, game)
        task.wait(0.015)
        VirtualInputManager:SendKeyEvent(false, key, false, game)
        task.wait(0.01)
    end
end

-- Auto parry loop
task.spawn(function()
    while true do
        task.wait(0.03)
        
        if not CONFIG.ParryEnabled then
            CONFIG.ParryLocked = false
            CONFIG.LastBallPos = nil
            continue
        end
        
        local char = Player.Character
        if not char then continue end
        local humanoidRootPart = char:FindFirstChild("HumanoidRootPart")
        if not humanoidRootPart then continue end
        local rootPos = humanoidRootPart.Position
        
        local nearestBall, nearestDist = findNearestBall()
        
        if nearestBall then
            local ballPos = nearestBall.Position
            local dist = (ballPos - rootPos).Magnitude
            
            if CONFIG.ParryLocked and CONFIG.LastBallPos then
                local ballMovedFar = (ballPos - CONFIG.LastBallPos).Magnitude > CONFIG.FarDist
                local ballIsFar = dist > CONFIG.FarDist
                local timeExpired = (tick() - CONFIG.BallLockTime) > CONFIG.SafetyTimeout
                
                if ballIsFar or ballMovedFar or timeExpired then
                    CONFIG.ParryLocked = false
                    CONFIG.LastBallPos = nil
                end
            end
            
            if dist < CONFIG.HitDistance and not CONFIG.ParryLocked then
                doParry()
                CONFIG.ParryLocked = true
                CONFIG.LastBallPos = ballPos
                CONFIG.BallLockTime = tick()
            end
            
            if CONFIG.ParryLocked then
                CONFIG.LastBallPos = ballPos
            end
        else
            if CONFIG.ParryLocked then
                local timeExpired = (tick() - CONFIG.BallLockTime) > CONFIG.SafetyTimeout
                if timeExpired then
                    CONFIG.ParryLocked = false
                    CONFIG.LastBallPos = nil
                end
            end
        end
    end
end)

