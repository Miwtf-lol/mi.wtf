-- Hàm chuyển đổi: giá trị slider 0-1 -> parry time 0.1s - 1.0s
local function parrySliderToTime(val)
    return 0.1 + val * 0.9  -- 0 -> 0.1s, 1 -> 1.0s
end

local function parryTimeToSlider(timeVal)
    return (timeVal - 0.1) / 0.9
end

local function applyParrySlider(val)
    val = math.clamp(val, 0, 1)
    parryCooldownTime = parrySliderToTime(val)
    parrySliderFill.Size = UDim2.new(val,0,1,0)
    parrySliderKnob.Position = UDim2.new(val,-5,0.5,-5)
    parrySliderLabel.Text = string.format("Parry Time: %.2fs", parryCooldownTime)
end

