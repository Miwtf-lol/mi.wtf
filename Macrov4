local function showNotification(featureName, state)
    local notifText = featureName .. (state and " § ON" or " § OFF")
    local notifColor = state and Color3.fromRGB(50, 255, 50) or Color3.fromRGB(255, 50, 50)
    
    -- Create notification frame
    local notif = Instance.new("Frame")
    notif.Size = UDim2.new(1, 0, 0, 32)
    notif.Position = UDim2.new(0, 0, 1, 0)
    notif.BackgroundColor3 = Colors.P4
    notif.BackgroundTransparency = 0.15
    notif.BorderSizePixel = 0
    notif.Parent = NotificationHolder
    
    local nCorner = Instance.new("UICorner")
    nCorner.CornerRadius = UDim.new(0, 6)
    nCorner.Parent = notif
    
    -- Left accent bar
    local accentBar = Instance.new("Frame")
    accentBar.Size = UDim2.new(0, 4, 1, 0)
    accentBar.BackgroundColor3 = notifColor
    accentBar.BorderSizePixel = 0
    accentBar.Parent = notif
    
    local aCorner = Instance.new("UICorner")
    aCorner.CornerRadius = UDim.new(0, 6)
    aCorner.Parent = accentBar
    
    -- Status dot
    local statusDot = Instance.new("Frame")
    statusDot.Name = "StatusDot"
    statusDot.Size = UDim2.new(0, 8, 0, 8)
    statusDot.Position = UDim2.new(0, 12, 0.5, -4)
    statusDot.BackgroundColor3 = notifColor
    statusDot.BorderSizePixel = 0
    statusDot.Parent = notif
    
    local dotCorner = Instance.new("UICorner")
    dotCorner.CornerRadius = UDim.new(1, 0)
    dotCorner.Parent = statusDot
    
    -- Text
    local label = Instance.new("TextLabel")
    label.Name = "Label"
    label.Size = UDim2.new(1, -30, 1, 0)
    label.Position = UDim2.new(0, 26, 0, 0)
    label.BackgroundTransparency = 1
    label.Text = notifText
    label.TextColor3 = Colors.P1
    label.TextStrokeTransparency = 0.7
    label.TextSize = 13
    label.Font = Enum.Font.GothamBold
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = notif
    
    -- Animate slide in from bottom
    notif.Position = UDim2.new(0, 0, 1, 0)
    local slideIn = TweenService:Create(notif, TweenInfo.new(0.3, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
        Position = UDim2.new(0, 0, 1, -36)
    })
    slideIn:Play()
    
    -- Auto-destroy after 2.5s with fade
    task.wait(2.2)
    local fadeOut = TweenService:Create(notif, TweenInfo.new(0.3, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
        BackgroundTransparency = 1
    })
    fadeOut:Play()
    
    -- Also fade label and dot
    local labelFade = TweenService:Create(label, TweenInfo.new(0.3, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
        TextTransparency = 1
    })
    labelFade:Play()
    
    local dotFade = TweenService:Create(statusDot, TweenInfo.new(0.3, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
        BackgroundTransparency = 1
    })
    dotFade:Play()
    
    task.wait(0.3)
    notif:Destroy()
end

