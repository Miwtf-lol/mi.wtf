-- === BALL TRAIL ===
local trailEnabled = true

task.spawn(function()
    while true do
        task.wait(0.1)
        if not trailEnabled then continue end
        
        local nearestBall, _ = findNearestBall()
        if nearestBall and CONFIG.ParryEnabled then
            local attachment = nearestBall:FindFirstChild("MiuTrailAttachment")
            if not attachment then
                attachment = Instance.new("Attachment")
                attachment.Name = "MiuTrailAttachment"
                attachment.Parent = nearestBall
                
                local trail = Instance.new("Trail")
                trail.Name = "MiuTrail"
                trail.Attachment0 = attachment
                trail.Attachment1 = attachment
                trail.Color = ColorSequence.new({
                    ColorSequenceKeypoint.new(0, Colors.P1),
                    ColorSequenceKeypoint.new(0.5, Colors.P2),
                    ColorSequenceKeypoint.new(1, Colors.P3),
                })
                trail.Transparency = NumberSequence.new(0.5)
                trail.Lifetime = 0.4
