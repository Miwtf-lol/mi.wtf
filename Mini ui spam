-- BALL DETECT
local function getBall()
    for _,v in pairs(Workspace:GetChildren()) do
        if v.Name == "ball" then
            return v
        end
    end
end

-- CHECK PARRY
local function canParry(ball)
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return false end

    local root = char.HumanoidRootPart
    local vel = ball.Velocity

    if vel.Magnitude < 1 then return false end

    local dist = (ball.Position - root.Position).Magnitude
    local time = dist / vel.Magnitude

    return time < mi_wtf.timing
end

-- MAIN LOOP
RunService.Heartbeat:Connect(function()
    local ball = getBall()
    if not ball then return end

    -- AUTO PARRY
    if mi_wtf.enabled and canParry(ball) then
        if tick() - mi_wtf.lastParry < mi_wtf.cooldown then return end
        mi_wtf.lastParry = tick()

        print("TRY PARRY")

        if mi_wtf.parryTool then
            local tool = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Tool")
            if tool then tool:Activate() end
        end

        if mi_wtf.parryRemote then
            local ev = ReplicatedStorage:FindFirstChild("events")
            if ev and ev:FindFirstChild("parry") then
                ev.parry:FireServer()
            end
        end
    end

    -- SPAM
    if mi_wtf.spam then
        local tool = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Tool")
        if tool then
            tool:Activate()
        end
    end
end)

print("mi.wtf PRO MAX loaded")
