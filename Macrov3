-- ===== TOGGLE GUI =====
local function setOpen(open)
    isOpen = open
    
    if open then
        local tween = TweenService:Create(MainFrame, TweenInfo.new(tweenTime, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            Size = UDim2.new(0, fullW, 0, fullH),
            Position = UDim2.new(0.5, -fullW/2, 0.5, -fullH/2)
        })
        tween:Play()
        
        task.delay(tweenTime * 0.6, function()
            Controls.Visible = true
        end)
    else
        Controls.Visible = false
        
        local tween = TweenService:Create(MainFrame, TweenInfo.new(tweenTime, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            Size = UDim2.new(0, miniW, 0, miniH),
            Position = UDim2.new(0.5, -miniW/2, 0.5, -miniH/2)
        })
        tween:Play()
    end
end

-- Click icon để toggle
IconButton.MouseButton1Click:Connect(function()
