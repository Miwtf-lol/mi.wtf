end
createAbilityValue()

-- ============================================
-- MODULE 2: AUTO PARRY ENGINE
-- ============================================
local AutoParryEngine = {}

function AutoParryEngine.chooseNewFocusedBall()
    local ballsFolder = Services.Workspace:FindFirstChild("Balls")
    if not ballsFolder then return nil end
    
    for _, ball in ipairs(ballsFolder:GetChildren()) do
        if ball:GetAttribute("realBall") == true or ball:GetAttribute("target") ~= nil then
            State.focusedBall = ball
            return ball
        end
    end
    return nil
end

function AutoParryEngine.getDynamicThreshold(velMagnitude)
    local BASE_THRESHOLD = 0.15
    if velMagnitude > 60 then
        return math.max(0.20, BASE_THRESHOLD - (velMagnitude * 0.050))
    else
        return math.min(0.01, BASE_THRESHOLD + (velMagnitude * 0.1))
    end
end

function AutoParryEngine.timeUntilImpact(ballVel, dist, playerVel)
    local dir = (State.character.HumanoidRootPart.Position - State.focusedBall.Position).Unit
    local velTowards = ballVel:Dot(dir) - playerVel:Dot(dir)
    if velTowards <= 0 then return math.huge end
    return (dist - State.sliderValue) / velTowards
end

function AutoParryEngine.checkBallDistance()
    if not State.character or not State.character:FindFirstChild("Highlight") then return end
    if not State.focusedBall or not State.focusedBall.Parent then
        AutoParryEngine.chooseNewFocusedBall()
    end
    if not State.focusedBall then return end

    local charPos = State.character.PrimaryPart.Position
    local charVel = State.character.PrimaryPart.Velocity
    local ball = State.focusedBall
    local dist = (ball.Position - charPos).Magnitude
    local velTowards = ball.Velocity:Dot((charPos - ball.Position).Unit)
    
    local parryRemote = Services.ReplicatedStorage.Remotes.ParryButtonPress
    local abilityRemote = Services.ReplicatedStorage.Remotes.AbilityButtonPress

    if dist < 10 then
        parryRemote:Fire()
        return
    end

    local time = AutoParryEngine.timeUntilImpact(ball.Velocity, dist, charVel)
    local threshold = AutoParryEngine.getDynamicThreshold(velTowards)
    
    if time < threshold then
        if State.character.Abilities["Raging Deflection"].Enabled and State.UseRage then
            abilityRemote:Fire()
            if State.character:FindFirstChildOfClass("Humanoid") and 
               State.character.Humanoid.WalkSpeed ~= 0 then
                parryRemote:Fire()
            end
        else
            parryRemote:Fire()
        end
    end
end

function AutoParryEngine.start()
    AutoParryEngine.chooseNewFocusedBall()
    State.heartbeatConnection = Services.RunService.Heartbeat:Connect(AutoParryEngine.checkBallDistance)
end

function AutoParryEngine.stop()
    if State.heartbeatConnection then
        State.heartbeatConnection:Disconnect()
        State.heartbeatConnection = nil
    end
end

-- ============================================
-- MODULE 3: ABILITY SWITCHER
-- ============================================
local AbilitySwitcher = {}

local ABILITIES = {
    "Dash", "Forcefield", "Invisibility", "Platform",
    "Raging Deflection", "Shadow Step", "Super Jump",
    "Telekinesis", "Thunder Dash", "Rapture"
}

function AbilitySwitcher.switchTo(abilityName)
    local args = { [1] = abilityName }
    Services.ReplicatedStorage.Remotes.Store.RequestEquipAbility:InvokeServer(unpack(args))
    Services.ReplicatedStorage.Remotes.Store.GetOwnedAbilities:InvokeServer()
    Services.ReplicatedStorage.Remotes.kebaind:FireServer()
    
    local existing = Services.Workspace:FindFirstChild("AbilityThingyk1212")
    if existing then existing:Remove() end
    
    local val = Instance.new("StringValue")
    val.Parent = Services.Workspace
    val.Name = "AbilityThingyk1212"
    val.Value = abilityName

    local abilities = State.abilitiesFolder:GetChildren()
    for _, v in ipairs(abilities) do
        if v.Enabled then
            for _, b in ipairs(abilities) do
                local abilVal = Services.Workspace:FindFirstChild("AbilityThingyk1212")
                if b.Name == abilVal.Value then
                    v.Enabled = false
                    b.Enabled = true
                    return
                end
            end
        end
    end
end

-- ============================================
-- MODULE 4: UPGRADES MODIFIER
-- ============================================
local UpgradesModifier = {}

local UPGRADE_NAMES = {
    "Dash", "Forcefield", "Invisibility", "Platform",
    "Shadow Step", "Super Jump", "Thunder Dash",
    "Raging Deflection", "Telekinesis"
}

function UpgradesModifier.setValue(name, value)
    local upg = State.localPlayer.Upgrades:FindFirstChild(name)
    if upg then upg.Value = value end
end

function UpgradesModifier.setAllPositive()
    for _, name in ipairs(UPGRADE_NAMES) do
        UpgradesModifier.setValue(name, 999999999999999999)
    end
end

function UpgradesModifier.setAllNegative()
    for _, name in ipairs(UPGRADE_NAMES) do
        UpgradesModifier.setValue(name, -999999999999999999)
    end
end

-- ============================================
-- MODULE 5: CRATE OPENER
-- ============================================
local CrateOpener = {}

function CrateOpener.openExplosion()
    local _, result = Services.ReplicatedStorage.Remotes.Store.RequestOpenExplosionBox:InvokeServer()
    Services.CoreGui:SetCore("SendNotification", {
        Title = "Explosion Crate", Text = result, Duration = 3
    })
    return result
end

function CrateOpener.openWeapon()
    local _, result = Services.ReplicatedStorage.Remotes.Store.RequestOpenSwordBox:InvokeServer()
    Services.CoreGui:SetCore("SendNotification", {
        Title = "Weapon Crate", Text = result, Duration = 3
    })
    return result
end

