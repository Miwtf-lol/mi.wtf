    Players = game:GetService("Players"),
    UserInputService = game:GetService("UserInputService"),
    ReplicatedStorage = game:GetService("ReplicatedStorage"),
    CoreGui = game:GetService("StarterGui"),
    VirtualUser = game:GetService("VirtualUser"),
    VirtualInput = game:GetService("VirtualInputManager"),
    TweenService = game:GetService("TweenService"),
}

local State = {
    localPlayer = Services.Players.LocalPlayer,
    character = nil,
    abilitiesFolder = nil,
    heartbeatConnection = nil,
    UseRage = false,
    sliderValue = 20,
    stayspawnshit = false,
    TpSpawn = false,
    FakePlatform = false,
    AntiAfkLol = false,
    breakballerbelike = false,
    OpenExplosionCrate = false,
    OpenSwordCrate = false,
    focusedBall = nil,
}

-- Init character
State.character = State.localPlayer.Character or State.localPlayer.CharacterAdded:Wait()
State.abilitiesFolder = State.character:WaitForChild("Abilities")

State.localPlayer.CharacterAdded:Connect(function(newChar)
    State.character = newChar
    State.abilitiesFolder = newChar:WaitForChild("Abilities")
end)

-- Tạo AbilityThingyk1212
local function createAbilityValue()
    local existing = Services.Workspace:FindFirstChild("AbilityThingyk1212")
    if existing then existing:Remove(); task.wait(0.1) end
    local val = Instance.new("StringValue")
    val.Parent = Services.Workspace
