-- ============================================
-- MODULE 7: SKINS ENGINE
-- ============================================
local SkinsEngine = {}

function SkinsEngine.applyEmpyreanGreatblade()
    local char = State.localPlayer.Character
    local sword = char:FindFirstChildOfClass("Model")
    local katanaMesh = sword:FindFirstChild("KatanaMesh")
    local empyrean = Services.ReplicatedStorage.Misc.Swords.Limited["Empyrean Greatblade"]
    local meshClone = empyrean["Meshes/Sword"]:Clone()
    
    meshClone.Anchored = false
    meshClone.Parent = sword
    meshClone.CFrame = katanaMesh.CFrame
    
    local weld = Instance.new("Weld")
    weld.Parent = meshClone
    weld.Part0 = meshClone
    weld.Part1 = katanaMesh
    katanaMesh.Transparency = 1
    
    char.HumanoidRootPart.CFrame = CFrame.new(-233.710556, 123.299973, 203.648102)
    task.wait(0.1)
    meshClone.Rotation = Vector3.new(-75.41799926757812, -90, 0)
end

function SkinsEngine.applyOniClaws()
    local char = State.localPlayer.Character
    local sword = char:FindFirstChildOfClass("Model")
    local claws = Services.ReplicatedStorage.Misc.Swords.Limited["Oni Claws"]:Clone()
    local katanaMesh = sword:FindFirstChild("KatanaMesh")
    
    claws.Parent = sword
    
    local weldL = Instance.new("Weld")
    weldL.Name = "Left Arm"
    weldL.Parent = claws.Cestus
    weldL.Part0 = claws.Cestus.zaza
    weldL.Part1 = char:FindFirstChild("Left Arm")
    
    local weldR = Instance.new("Weld")
    weldR.Name = "Right Arm"
    weldR.Parent = claws.Cestus2
    weldR.Part0 = claws.Cestus2.zaza
    weldR.Part1 = char:FindFirstChild("Right Arm")
    
    katanaMesh.Transparency = 1
    for _, part in ipairs({"sord", "handle", "WhiteFlameCharges", "Excalibur"}) do
        local obj = sword:FindFirstChild(part)
        if obj then obj:Remove() end
    end
end

function SkinsEngine.applyFunniOniClaws()
    local char = State.localPlayer.Character
    local sword = char:FindFirstChildOfClass("Model")
    local claws = Services.ReplicatedStorage.Misc.Swords.Limited["Oni Claws"]:Clone()
    local claws2 = Services.ReplicatedStorage.Misc.Swords.Limited["Oni Claws"]:Clone()
    local katanaMesh = sword:FindFirstChild("KatanaMesh")
    
    claws.Parent = sword
    local wL = Instance.new("Weld"); wL.Name = "Left Arm"; wL.Parent = claws.Cestus
    wL.Part0 = claws.Cestus.zaza; wL.Part1 = char:FindFirstChild("Left Arm")
    
    local wR = Instance.new("Weld"); wR.Name = "Right Arm"; wR.Parent = claws.Cestus2
    wR.Part0 = claws.Cestus2.zaza; wR.Part1 = char:FindFirstChild("Right Arm")
    
    claws2.Parent = sword
    local wL2 = Instance.new("Weld"); wL2.Name = "Left Arm2"; wL2.Parent = claws2.Cestus2
    wL2.Part0 = claws2.Cestus2.zaza; wL2.Part1 = char:FindFirstChild("Left Arm")
    
    local wR2 = Instance.new("Weld"); wR2.Name = "Right Arm2"; wR2.Parent = claws2.Cestus
    wR2.Part0 = claws2.Cestus.zaza; wR2.Part1 = char:FindFirstChild("Right Arm")
    
    katanaMesh.Transparency = 1
    for _, p in ipairs({"sord", "handle", "WhiteFlameCharges", "Excalibur"}) do
        local o = sword:FindFirstChild(p)
        if o then o:Remove() end
    end
end

function SkinsEngine.applyGodSaber()
    local char = State.localPlayer.Character
    local sword = char:FindFirstChildOfClass("Model")
    local katanaMesh = sword:FindFirstChild("KatanaMesh")
    local godsaber = Services.ReplicatedStorage.Misc.Swords.Unique.Godsaber
    
    if sword:FindFirstChild("Godsaber") then
        sword.Godsaber:Remove(); task.wait(0.1)
    end
    
    local clone = godsaber:Clone()
    clone.Parent = sword
    
    local katMesh = godsaber:FindFirstChild("KatanaMesh")
    local handle = godsaber:FindFirstChild("handle")
    local sord = godsaber:FindFirstChild("sord")
    local blade = godsaber:FindFirstChild("Blade")
    local main = blade and blade:FindFirstChild("Main")
    
    if katMesh then katMesh.Anchored = false end
    if handle then handle.Anchored = false end
    if sord then sord.Anchored = false end
    if blade then blade.Anchored = false end
    if main then main.Anchored = false end
    
    if sord then sord.CFrame = katanaMesh.CFrame end
    if handle then handle.CFrame = katanaMesh.CFrame + Vector3.new(0, 0.6, -1.5) end
    if katMesh then 
        katMesh.CFrame = katanaMesh.CFrame
        local wc = katMesh:FindFirstChild("WeldConstraint")
        if wc then wc.Part1 = char:FindFirstChild("Left Leg") end
    end
    if main then main.CFrame = katanaMesh.CFrame end
    
    char.HumanoidRootPart.CFrame = CFrame.new(-233.710556, 123.299973, 203.648102)
    task.wait(0.2)
    
    if main then main.Rotation = Vector3.new(112, 0, 90) end
    if handle then handle.Rotation = Vector3.new(-159, 0, 100) end
    
    katanaMesh.Transparency = 1
    for _, p in ipairs({"sord", "handle", "WhiteFlameCharges", "Excalibur"}) do
        local o = sword:FindFirstChild(p)
        if o then o:Remove() end
    end
end

