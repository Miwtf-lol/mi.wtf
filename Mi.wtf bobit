-- Mobile Detection (Bobit Feature)
if UserInputService.TouchEnabled and not UserInputService.KeyboardEnabled then
    Settings.Mobile = true
end

-- Bobit Exact Main Loop
local LastParry = 0
RunService.Heartbeat:Connect(function()
    UpdateBall()
    
    if Ball and Settings.Enabled then
        local Character = LocalPlayer.Character
        if Character and Character:FindFirstChild("HumanoidRootPart") then
            local RootPart = Character.HumanoidRootPart
            local BallPosition = Ball.Position
            local BallVelocity = Ball.Velocity
            
            local Distance = (RootPart.Position - BallPosition).Magnitude
            if Distance < 39.5 and BallVelocity.Magnitude > 10 then
                local Direction = (RootPart.Position - BallPosition).Unit
                local BallDirection = BallVelocity.Unit
                
                local DotProduct = Direction:Dot(BallDirection)
                
                if DotProduct > 0.9434 and tick() - LastParry > 0.13 then
                    local Events = ReplicatedStorage:FindFirstChild("events")
                    if Events then
                        local ParryEvent = Events:FindFirstChild("parry")
                        if ParryEvent then
                            ParryEvent:FireServer()
                            LastParry = tick()
                            StatusLabel.Text = "Status: PARRY!"
                        end
                    end
                else
                    StatusLabel.Text = "Status: Active"
                end
            else
                StatusLabel.Text = "Status: Waiting..."
            end
        end
    end
    
    -- FOV Updates
    if Settings.ShowFOV then
        FOVCircle.Visible = true
        FOVCircle.Size = UDim2.new(0, Settings.FOVSize * 2, 0, Settings.FOVSize * 2)
        FOVCircle.Position = UDim2.new(0.5, -Settings.FOVSize, 0.5, -Settings.FOVSize)
    else
        FOVCircle.Visible = false
    end
end)

