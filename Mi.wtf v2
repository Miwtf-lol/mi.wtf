    Label.Size = UDim2.new(1, -70, 1, 0)
    Label.Font = Enum.Font.GothamBold
    Label.Text = icon .. "  " .. name
    Label.TextColor3 = color or Color3.fromRGB(255, 255, 255)
    Label.TextSize = 18
    Label.TextXAlignment = Enum.TextXAlignment.Left
    
    local Switch = Instance.new("TextButton")
    Switch.Parent = ToggleFrame
    Switch.BackgroundColor3 = Color3.fromRGB(50, 50, 80)
    Switch.Position = UDim2.new(1, -60, 0, 8)
    Switch.Size = UDim2.new(0, 45, 0, 34)
    Switch.Font = Enum.Font.GothamBold
    Switch.Text = "OFF"
    Switch.TextColor3 = Color3.fromRGB(255, 100, 100)
    Switch.TextSize = 14
    
    local SwitchCorner = Instance.new("UICorner")
    SwitchCorner.CornerRadius = UDim.new(0, 12)
    SwitchCorner.Parent = Switch
    
    local enabled = false
    Switch.MouseButton1Click:Connect(function()
        enabled = not enabled
        Switch.Text = enabled and "ON" or "OFF"
        Switch.TextColor3 = enabled and Color3.fromRGB(100, 255, 100) or Color3.fromRGB(255, 100, 100)
        Switch.BackgroundColor3 = enabled and Color3.fromRGB(30, 80, 30) or Color3.fromRGB(80, 30, 30)
        callback(enabled)
    end)
    
    return ToggleFrame
end

