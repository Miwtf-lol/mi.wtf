-- ENHANCED BALL DETECTION
local function getBall()
    for _, obj in pairs(Workspace:GetChildren()) do
        if obj.Name == "ball" and obj:FindFirstChild("UnionOperation") and obj:FindFirstChild("Velocity") then
            return obj
        end
    end
    return nil
end

-- NEAREST TARGET DETECTION
local function getNearestTarget()
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return nil end
    
    local closestPlayer = nil
    local shortestDistance = math.huge
    
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            local distance = (player.Character.HumanoidRootPart.Position - char.HumanoidRootPart.Position).Magnitude
            if distance < shortestDistance and distance < 150 then
                shortestDistance = distance
                closestPlayer = player
            end
        end
    end
    
    return closestPlayer
end

-- 🔥 AUTO HIT LOGIC (MAIN FEATURE)
local function autoHitBall(ball)
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    
    local rootPart = char.HumanoidRootPart
    local ballPos = ball.Position
    local rootPos = rootPart.Position
    
    -- Perfect aim direction
    local direction = (ballPos - rootPos).Unit
    
    -- Simulate swing/hit
    if VIP_CONFIG.aimAssist then
        -- Body aim assist
        rootPart.CFrame = CFrame.lookAt(rootPos, ballPos)
    end
    
    -- Fire hit remote (Blade Ball hit mechanism)
    local events = ReplicatedStorage:FindFirstChild("events")
    if events then
        -- Hit remote
        local hitRemote = events:FindFirstChild("hitBall") or events:FindFirstChild("swing") or events:FindFirstChild("hit")
        if hitRemote then
            pcall(function()
                hitRemote:FireServer(ball)
            end)
        end
        
        -- Alternative hit method
        local parryRemote = events:FindFirstChild("parry")
        if parryRemote then
            pcall(function()
                parryRemote:FireServer()
            end)
        end
    end
    
    -- Tool activation (sword/swing)
    local tool = char:FindFirstChildOfClass("Tool")
    if tool then
        tool:Activate()
    end
end

-- ADVANCED PARRY DETECTION
local function shouldParry(ball)
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return false end
    
    local rootPart = char.HumanoidRootPart
    local ballVel = ball.Velocity
    local distance = (ball.Position - rootPart.Position).Magnitude
    
    if ballVel.Magnitude < 8 or distance > 90 then return false end
    
    local directionToPlayer = (rootPart.Position - ball.Position).Unit
    local ballDirection = ballVel.Unit
    local dot = directionToPlayer:Dot(ballDirection)
    
    return dot > 0.85 and distance / ballVel.Magnitude <= VIP_CONFIG.combat.parryTiming
end

-- AUTO HIT DETECTION (BALL COMING TOWARDS YOU)
local function shouldHitBall(ball)
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return false end
    
    local rootPart = char.HumanoidRootPart
    local ballVel = ball.Velocity
    local distance = (ball.Position - rootPart.Position).Magnitude
    
    if ballVel.Magnitude < 5 or distance > 120 then return false end
    
    -- Check if ball is near or controllable
    local timeToReach = distance / ballVel.Magnitude
    return timeToReach <= 1.2 or distance < 40
end

