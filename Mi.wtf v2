-- Enhanced Ball Detection
local function getBall()
    for _, obj in pairs(Workspace:GetChildren()) do
        if obj.Name == "ball" and obj:FindFirstChild("UnionOperation") and obj:FindFirstChild("Velocity") then
            return obj
        end
    end
    return nil
end

-- Advanced Prediction Algorithm (VIP Quality)
local function advancedPredict(ball, target, deltaTime)
    local ballPos = ball.Position
    local ballVel = ball.Velocity
    local targetPos = target.Character.HumanoidRootPart.Position
    
    if VIP_CONFIG.prediction.arcPrediction then
        local gravity = VIP_CONFIG.prediction.gravity
        local timeToTarget = 0.1
        
        for i = 1, VIP_CONFIG.prediction.trajectorySamples do
            local predictedPos = ballPos + (ballVel * timeToTarget) - Vector3.new(0, 0.5 * gravity * timeToTarget^2, 0)
            local distToTarget = (predictedPos - targetPos).Magnitude
            
            if distToTarget < 25 then
                return predictedPos, timeToTarget
            end
            
            timeToTarget = timeToTarget + (deltaTime * 0.1)
        end
    end
    
    local direction = (targetPos - ballPos).Unit
    local distance = (targetPos - ballPos).Magnitude
    local timeToHit = distance / VIP_CONFIG.prediction.speed
    
    local predictedPos = ballPos + (direction * (distance * 0.95)) + (ballVel * timeToHit * 0.8)
    return predictedPos, timeToHit
end

-- Premium Parry Detection
local function shouldParry(ball)
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") or not char:FindFirstChild("Humanoid") then 
        return false 
    end

    local rootPart = char.HumanoidRootPart
    local humanoid = char.Humanoid
    local ballPos = ball.Position
    local ballVel = ball.Velocity
    
    if ballVel.Magnitude < 5 then return false end
    
    local distance = (ballPos - rootPart.Position).Magnitude
    if distance > 80 then return false end
    
    local directionToBall = (ballPos - rootPart.Position).Unit
    local ballDirection = ballVel.Unit
    local dotProduct = directionToBall:Dot(ballDirection)
    
    if dotProduct < 0.82 then return false end
    
    local timeToImpact = distance / ballVel.Magnitude
    local pingComp = VIP_CONFIG.prediction.pingCompensation / 1000
    
    local perfectTiming = VIP_CONFIG.safety.humanizeTiming and 
        (timeToImpact - pingComp) <= 0.18 and (timeToImpact - pingComp) >= 0.08 or
        timeToImpact <= 0.22
    
    return perfectTiming
end

